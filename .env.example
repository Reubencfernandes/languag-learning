# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database ---
# Local dev (docker-compose): postgres://langlearn:langlearn@localhost:5432/langlearn
DATABASE_URL=postgres://langlearn:langlearn@localhost:5432/langlearn

# --- Auth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me

# --- HuggingFace OAuth ---
# Create an OAuth app at https://huggingface.co/settings/applications/new
# Redirect URIs (add both):
#   http://localhost:3000/api/auth/callback/huggingface
#   langlearn://auth/callback     (for Flutter)
# Scopes: openid profile email
HF_OAUTH_CLIENT_ID=
HF_OAUTH_CLIENT_SECRET=

# --- HuggingFace Inference ---
# Personal access token: https://huggingface.co/settings/tokens (read)
HF_TOKEN=

# --- Object storage (Vercel Blob) ---
# From `vercel env pull` or dashboard
BLOB_READ_WRITE_TOKEN=
